        "language": { "name": "Language", "description": "Output language code." }
      }
    },
    "download": {
      "name": "Download artifact",
      "description": "Download a generated artifact to a file inside Home Assistant.",
      "fields": {
        "config_entry_id": { "name": "Account", "description": "Which NotebookLM account to use." },
        "notebook_id": { "name": "Notebook ID", "description": "Target notebook." },
        "artifact_type": { "name": "Type", "description": "Which artifact type to download." },
        "output_path": { "name": "Output path", "description": "Destination path inside an allowed directory." },
